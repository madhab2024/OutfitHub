{
  "name": "multi-vendor-clothing-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "shared",
    "apps/admin",
    "apps/customer",
    "apps/logistic",
    "apps/shopowner"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:admin dev:customer dev:logistic dev:shopowner",
    "dev:backend": "npm run dev -w backend",
    "dev:admin": "npm run dev -w admin",
    "dev:customer": "npm run dev -w customer",
    "dev:logistic": "npm run dev -w logistic",
    "dev:shopowner": "npm run dev -w shopowner",
    "build": "npm-run-all build:shared build:backend build:admin build:customer build:logistic build:shopowner",
    "build:shared": "npm run build -w @platform/shared",
    "build:backend": "npm run build -w backend",
    "build:admin": "npm run build -w admin",
    "build:customer": "npm run build -w customer",
    "build:logistic": "npm run build -w logistic",
    "build:shopowner": "npm run build -w shopowner"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}